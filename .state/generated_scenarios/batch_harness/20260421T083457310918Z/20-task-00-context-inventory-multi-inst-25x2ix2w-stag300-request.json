{
  "name": "vps-docker-qwen3-235b-multi-inst-25x2ix2w-stag300-request",
  "runtime": {
    "kind": "docker",
    "image": "dr34m/openclaw:latest",
    "container_name_base": "openclaw-bench-vps-v2",
    "host": "127.0.0.1",
    "instance_num": 2,
    "host_port": 19189,
    "container_port": 19189,
    "network_mode": "host",
    "gateway_bind": "loopback",
    "gateway_token": "openclaw-bench-token",
    "build_image_if_missing": true,
    "force_rebuild": false,
    "skip_channels": true,
    "keep_container": false,
    "startup_timeout_sec": 240,
    "env": {
      "VLLM_API_KEY": "sk-local-ascend"
    },
    "openclaw_config": {
      "agents": {
        "defaults": {
          "thinkingDefault": "off",
          "model": {
            "primary": "vllm/qwen3-235b"
          },
          "params": {
            "temperature": 0,
            "maxTokens": 1024
          }
        }
      },
      "models": {
        "providers": {
          "vllm": {
            "baseUrl": "http://127.0.0.1:18000/v1",
            "apiKey": "${VLLM_API_KEY}",
            "api": "openai-completions",
            "models": [
              {
                "id": "qwen3-235b",
                "name": "Local vLLM Qwen3-235B",
                "reasoning": false,
                "input": [
                  "text"
                ],
                "cost": {
                  "input": 0,
                  "output": 0,
                  "cacheRead": 0,
                  "cacheWrite": 0
                },
                "contextWindow": 262144,
                "maxTokens": 1024,
                "compat": {
                  "supportsUsageInStreaming": true
                }
              }
            ]
          }
        }
      }
    }
  },
  "client": {
    "role": "operator",
    "message": "",
    "task_file": "/root/Zehao/ClawHarness/tasks/task_00_context_inventory.md",
    "session_prefix": "vps-docker-qwen3-235b-multi-inst-25x2ix2w-stag300-request",
    "session_mode": "per_request",
    "history_limit": 20,
    "wait_timeout_ms": 600000,
    "send_timeout_ms": 150000
  },
  "load": {
    "concurrency": 2,
    "requests_per_worker": 25,
    "worker_stagger_ms": 300,
    "request_pause_ms": 0
  },
  "collectors": {
    "docker_stats": {
      "enabled": true,
      "interval_ms": 1000
    },
    "pidstat": {
      "enabled": true,
      "interval_sec": 1
    },
    "strace": {
      "enabled": false
    },
    "node_trace": {
      "enabled": true
    },
    "iostat": {
      "enabled": true,
      "interval_sec": 1
    },
    "perf_stat": {
      "enabled": false
    },
    "perf_record": {
      "enabled": false
    },
    "vmstat": {
      "enabled": true,
      "interval_sec": 1
    },
    "npu_smi": {
      "enabled": true,
      "interval_sec": 1,
      "auto_discover": true,
      "card_ids": []
    }
  },
  "artifacts": {
    "summary_only": false
  }
}
