{
  "name": "vps-host-direct-single-npu-smoke",
  "runtime": {
    "kind": "host_direct",
    "host": "127.0.0.1",
    "gateway_token": "openclaw-bench-token",
    "startup_timeout_sec": 240
  },
  "client": {
    "role": "operator",
    "message": "/context list",
    "session_prefix": "vps-host-direct-single-npu-smoke",
    "session_mode": "per_worker",
    "history_limit": 20,
    "wait_timeout_ms": 15000,
    "send_timeout_ms": 15000
  },
  "load": {
    "concurrency": 1,
    "requests_per_worker": 5,
    "worker_stagger_ms": 0,
    "request_pause_ms": 100
  },
  "collectors": {
    "docker_stats": {
      "enabled": true,
      "interval_ms": 1000
    },
    "pidstat": {
      "enabled": true,
      "interval_sec": 1
    },
    "strace": {
      "enabled": false
    },
    "node_trace": {
      "enabled": true
    },
    "iostat": {
      "enabled": true,
      "interval_sec": 1
    },
    "perf_stat": {
      "enabled": false
    },
    "perf_record": {
      "enabled": false
    },
    "vmstat": {
      "enabled": true,
      "interval_sec": 1
    },
    "npu_smi": {
      "enabled": true,
      "interval_sec": 1,
      "card_ids": [0, 1, 2, 3, 4, 5, 6, 7]
    }
  },
  "artifacts": {
    "summary_only": true
  }
}
