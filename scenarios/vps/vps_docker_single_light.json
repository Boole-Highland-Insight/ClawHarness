{
  "name": "vps-docker-single-task-00-500-light",
  "runtime": {
    "kind": "docker",
    "image": "openclaw:bench-local-v2",
    "container_name_base": "openclaw-bench-vps-v2",
    "host": "127.0.0.1",
    "host_port": 19189,
    "container_port": 18789,
    "gateway_bind": "lan",
    "gateway_token": "openclaw-bench-token",
    "build_image_if_missing": false,
    "force_rebuild": false,
    "skip_channels": true,
    "startup_timeout_sec": 240
  },
  "client": {
    "role": "operator",
    "message": "/context list",
    "session_prefix": "vps-docker-single-task-00-500-light",
    "session_mode": "per_worker",
    "history_limit": 20,
    "wait_timeout_ms": 15000,
    "send_timeout_ms": 15000
  },
  "load": {
    "concurrency": 1,
    "requests_per_worker": 500,
    "worker_stagger_ms": 0,
    "request_pause_ms": 0
  },
  "collectors": {
    "docker_stats": {
      "enabled": true,
      "interval_ms": 1000
    },
    "pidstat": {
      "enabled": true,
      "interval_sec": 1
    },
    "strace": {
      "enabled": false
    },
    "node_trace": {
      "enabled": true
    },
    "iostat": {
      "enabled": true,
      "interval_sec": 1
    },
    "perf_stat": {
      "enabled": false
    },
    "perf_record": {
      "enabled": false
    },
    "vmstat": {
      "enabled": true,
      "interval_sec": 1
    }
  },
  "artifacts": {
    "summary_only": true
  }
}
