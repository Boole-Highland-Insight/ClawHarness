{
  "name": "docker-multi-task-00-100-full",
  "runtime": {
    "kind": "docker",
    "image": "openclaw:bench-local",
    "container_name_base": "openclaw-bench",
    "host": "127.0.0.1",
    "host_port": 19190,
    "container_port": 18789,
    "gateway_bind": "lan",
    "gateway_token": "openclaw-bench-token",
    "build_image_if_missing": true,
    "force_rebuild": false,
    "skip_channels": true,
    "startup_timeout_sec": 240
  },
  "client": {
    "role": "operator",
    "message": "/context list",
    "session_prefix": "bench-multi-100-full",
    "session_mode": "per_worker",
    "history_limit": 20,
    "wait_timeout_ms": 15000,
    "send_timeout_ms": 15000
  },
  "load": {
    "concurrency": 20,
    "requests_per_worker": 5,
    "worker_stagger_ms": 150,
    "request_pause_ms": 0
  },
  "collectors": {
    "docker_stats": {
      "enabled": true,
      "interval_ms": 1000
    },
    "pidstat": {
      "enabled": true,
      "interval_sec": 1
    },
    "iostat": {
      "enabled": true,
      "interval_sec": 1
    },
    "perf_stat": {
      "enabled": true
    },
    "perf_record": {
      "enabled": true
    }
  },
  "artifacts": {
    "summary_only": false
  }
}
