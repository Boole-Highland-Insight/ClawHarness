{
  "name": "vllm-multi-task-05-100",
  "runtime": {
    "kind": "host_direct",
    "host": "127.0.0.1",
    "host_port": 18000,
    "endpoint_url": "http://127.0.0.1:18000/v1/chat/completions",
    "healthcheck_url": "http://127.0.0.1:18000/health",
    "startup_timeout_sec": 240
  },
  "client": {
    "role": "operator",
    "transport": "openai_chat_completions",
    "message": "",
    "task_file": "../../tasks/task_05_semianalysis_title.md",
    "session_prefix": "bench-vllm-task-05-100",
    "session_mode": "per_worker",
    "history_limit": 20,
    "model": "REPLACE_WITH_YOUR_VLLM_MODEL_NAME",
    "api_key": "sk-local-ascend",
    "wait_timeout_ms": 60000,
    "send_timeout_ms": 15000
  },
  "load": {
    "concurrency": 20,
    "requests_per_worker": 5,
    "worker_stagger_ms": 150,
    "request_pause_ms": 0
  },
  "collectors": {
    "docker_stats": {
      "enabled": false,
      "interval_ms": 1000
    },
    "pidstat": {
      "enabled": true,
      "interval_sec": 1
    },
    "iostat": {
      "enabled": true,
      "interval_sec": 1
    },
    "perf_stat": {
      "enabled": true
    },
    "perf_record": {
      "enabled": true
    }
  },
  "artifacts": {
    "summary_only": false
  }
}
